{
  "name": "fablabrobot",
  "version": "1.0.0",
  "private": true,
  "description": "Sass toolchain for Fablabrobot CSS preprocessing",
  "scripts": {
    "scss:build": "sass public/scss/main.scss:public/css/scss-build/main.css public/scss/admin.scss:public/css/scss-build/admin.css public/scss/entries/typographie.scss:public/css/typographie.css public/scss/entries/public-notification.scss:public/css/public-notification.css public/scss/entries/webtv.scss:public/css/webtv.css public/scss/entries/utilisateurs.scss:public/css/utilisateurs.css public/scss/entries/contact.scss:public/css/contact.css public/scss/entries/projets.scss:public/css/projets.css public/scss/entries/actualites.scss:public/css/actualites.css public/scss/entries/cartes-partagees.scss:public/css/cartes-partagees.css public/scss/entries/listes-partagees.scss:public/css/listes-partagees.css public/scss/entries/filtres-catalogue.scss:public/css/filtres-catalogue.css public/scss/entries/details-partages.scss:public/css/details-partages.css public/scss/entries/header-auth.scss:public/css/header-auth.css public/scss/entries/adminconnexion.scss:public/css/Adminconnexion.css public/scss/entries/pagination.scss:public/css/pagination.css --style=expanded --no-source-map",
    "scss:build:min": "sass public/scss/main.scss:public/css/scss-build/main.min.css public/scss/admin.scss:public/css/scss-build/admin.min.css public/scss/entries/typographie.scss:public/css/typographie.min.css public/scss/entries/public-notification.scss:public/css/public-notification.min.css public/scss/entries/webtv.scss:public/css/webtv.min.css public/scss/entries/utilisateurs.scss:public/css/utilisateurs.min.css public/scss/entries/contact.scss:public/css/contact.min.css public/scss/entries/projets.scss:public/css/projets.min.css public/scss/entries/actualites.scss:public/css/actualites.min.css public/scss/entries/cartes-partagees.scss:public/css/cartes-partagees.min.css public/scss/entries/listes-partagees.scss:public/css/listes-partagees.min.css public/scss/entries/filtres-catalogue.scss:public/css/filtres-catalogue.min.css public/scss/entries/details-partages.scss:public/css/details-partages.min.css public/scss/entries/header-auth.scss:public/css/header-auth.min.css public/scss/entries/adminconnexion.scss:public/css/Adminconnexion.min.css public/scss/entries/pagination.scss:public/css/pagination.min.css --style=compressed --no-source-map",
    "scss:watch": "sass --watch public/scss/main.scss:public/css/scss-build/main.css public/scss/admin.scss:public/css/scss-build/admin.css public/scss/entries/typographie.scss:public/css/typographie.css public/scss/entries/public-notification.scss:public/css/public-notification.css public/scss/entries/webtv.scss:public/css/webtv.css public/scss/entries/utilisateurs.scss:public/css/utilisateurs.css public/scss/entries/contact.scss:public/css/contact.css public/scss/entries/projets.scss:public/css/projets.css public/scss/entries/actualites.scss:public/css/actualites.css public/scss/entries/cartes-partagees.scss:public/css/cartes-partagees.css public/scss/entries/listes-partagees.scss:public/css/listes-partagees.css public/scss/entries/filtres-catalogue.scss:public/css/filtres-catalogue.css public/scss/entries/details-partages.scss:public/css/details-partages.css public/scss/entries/header-auth.scss:public/css/header-auth.css public/scss/entries/adminconnexion.scss:public/css/Adminconnexion.css public/scss/entries/pagination.scss:public/css/pagination.css --style=expanded --no-source-map",
    "encoding:check": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/check-encoding.ps1"
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "sass": "^1.93.0"
  }
}
